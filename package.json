{
  "name": "meufluxo-frontend",
  "private": true,
  "packageManager": "pnpm@9.15.6",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "turbo dev",
    "dev:web": "turbo dev --filter=web",
    "build": "turbo build",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "clean": "turbo clean && rimraf node_modules"
  },
  "devDependencies": {
    "prettier": "^3.6.2",
    "rimraf": "^6.0.1",
    "turbo": "^2.5.6",
    "typescript": "^5.8.3"
  }
}

